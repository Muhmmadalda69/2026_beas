# Copy to .env and adjust before deploying. docker-compose reads this file.
# For production, `./deploy.sh` auto-generates the secrets below on first run —
# you normally only need to set the Google + URL values manually.

# Shared secret used to sign/verify JWTs across all services. MUST be a long,
# random value in production (deploy.sh generates one for you).
JWT_SECRET=change-me-please-use-a-32-byte-random-secret
JWT_TTL=12h

# Comma-separated list of browser origins allowed to call the API.
# Production (port 80): set to your public origin, e.g. http://your-domain
CORS_ORIGINS=http://localhost:3000

# Postgres password (used by every service's DSN). deploy.sh generates this on
# first run. Do NOT change it after the database volume is created.
POSTGRES_PASSWORD=galuh

# Initial superadmin account, seeded on first boot of the auth service.
# deploy.sh generates a strong ADMIN_PASSWORD on first deploy and prints it once.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345

# Public base URL of the gateway (browser uses same-origin proxy, so this is
# only a server-side fallback). Leave as-is for the dockerized stack.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Send the Secure flag on session cookies. Keep "false" when serving over plain
# HTTP (e.g. port 80 without TLS); set "true" only behind HTTPS.
COOKIE_SECURE=false

# Shared secret the frontend uses for server-to-server OAuth upsert calls to the
# auth service. MUST be random in production (deploy.sh generates one).
INTERNAL_API_SECRET=internal-shared-secret-change-me

# Google OAuth (optional). Leave empty to disable the Google login button.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match exactly. For production on port 80:
#   http://your-domain/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
