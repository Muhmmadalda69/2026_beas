# Copy to .env and adjust before deploying. docker-compose reads this file.

# Shared secret used to sign/verify JWTs across all services. MUST be a long,
# random value in production (e.g. `openssl rand -base64 48`).
JWT_SECRET=change-me-please-use-a-32-byte-random-secret
JWT_TTL=12h

# Comma-separated list of browser origins allowed to call the API.
CORS_ORIGINS=http://localhost:3000

# Postgres password (used by every service's DSN).
POSTGRES_PASSWORD=galuh

# Initial admin account, seeded on first boot of the auth service.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345

# Public base URL of the gateway, baked into the frontend for browser calls.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Shared secret the frontend uses for server-to-server OAuth upsert calls to the
# auth service. MUST be random in production.
INTERNAL_API_SECRET=internal-shared-secret-change-me

# Google OAuth (optional). Leave empty to disable the Google login button.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
